{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": "src",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["src/main/**/*.ts", "src/ai/**/*.ts", "src/utils/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", "src/**/__tests__/**", "**/*.test.ts", "**/*.spec.ts"]
}
